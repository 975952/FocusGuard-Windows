<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="专注守卫" Width="1120" Height="770" MinWidth="980" MinHeight="690"
        WindowStartupLocation="CenterScreen" Background="#F3F6F2"
        FontFamily="Microsoft YaHei UI" ShowInTaskbar="True"
        UseLayoutRounding="True" SnapsToDevicePixels="True">
  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="#17211D"/>
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="Background" Value="#FFFFFF"/>
      <Setter Property="Foreground" Value="#17211D"/>
      <Setter Property="BorderBrush" Value="#D8E0DA"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="11,8"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="CaretBrush" Value="#167A57"/>
      <Setter Property="SelectionBrush" Value="#9ED7C0"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border x:Name="InputBorder" Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8" Padding="{TemplateBinding Padding}">
              <ScrollViewer x:Name="PART_ContentHost"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter TargetName="InputBorder" Property="BorderBrush" Value="#16825C"/>
                <Setter TargetName="InputBorder" Property="BorderThickness" Value="1.5"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="InputBorder" Property="Background" Value="#EDF1ED"/>
                <Setter Property="Foreground" Value="#89928D"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="ComboBox">
      <Setter Property="Background" Value="#FFFFFF"/>
      <Setter Property="Foreground" Value="#17211D"/>
      <Setter Property="BorderBrush" Value="#D8E0DA"/>
      <Setter Property="Padding" Value="9,6"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="MinHeight" Value="37"/>
    </Style>
    <Style x:Key="PrimaryButton" TargetType="Button">
      <Setter Property="Background" Value="#167A57"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="20,11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="MinHeight" Value="42"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="9" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.86"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.70"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.38"/>
                <Setter Property="Cursor" Value="Arrow"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
      <Setter Property="Background" Value="#E8EFEA"/>
      <Setter Property="Foreground" Value="#234136"/>
      <Setter Property="BorderBrush" Value="#D4DED7"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
      <Setter Property="Background" Value="#3C3331"/>
      <Setter Property="Foreground" Value="#F7D7D0"/>
      <Setter Property="BorderBrush" Value="#66514C"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
      <Setter Property="Padding" Value="12,6"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="MinHeight" Value="32"/>
    </Style>
    <Style x:Key="ChipButton" TargetType="Button" BasedOn="{StaticResource SmallButton}">
      <Setter Property="Padding" Value="10,5"/>
      <Setter Property="MinHeight" Value="29"/>
      <Setter Property="Margin" Value="0,0,7,0"/>
    </Style>
    <Style x:Key="SessionProgressStyle" TargetType="ProgressBar">
      <Setter Property="Height" Value="7"/>
      <Setter Property="Foreground" Value="#67D4A0"/>
      <Setter Property="Background" Value="#31433C"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ProgressBar">
            <Grid>
              <Border Background="{TemplateBinding Background}" CornerRadius="4"/>
              <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                      HorizontalAlignment="Left" CornerRadius="4"/>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="FieldLabel" TargetType="TextBlock">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#25362F"/>
    </Style>
    <Style x:Key="FieldHint" TargetType="TextBlock">
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="Foreground" Value="#7E8A84"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    <Style x:Key="SettingsTabItem" TargetType="TabItem">
      <Setter Property="Foreground" Value="#5D6A64"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabItem">
            <Border x:Name="TabPill" Background="#EDF2EE" CornerRadius="9"
                    Padding="15,8" Margin="0,0,8,0">
              <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                TextElement.Foreground="{TemplateBinding Foreground}"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="TabPill" Property="Background" Value="#173F31"/>
                <Setter Property="Foreground" Value="White"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="TabPill" Property="Opacity" Value="0.86"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="SettingsTabControl" TargetType="TabControl">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabControl">
            <Grid KeyboardNavigation.TabNavigation="Local">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <TabPanel x:Name="HeaderPanel" Grid.Row="0" IsItemsHost="True"/>
              <Border Grid.Row="1" Padding="0,17,0,0">
                <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent"/>
              </Border>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid Margin="28,24,28,20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,22">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal">
        <Border Width="46" Height="46" CornerRadius="14" Background="#123E30" Margin="0,0,13,0">
          <Grid>
            <Ellipse Width="24" Height="24" Stroke="#72D8A8" StrokeThickness="3"/>
            <Ellipse Width="7" Height="7" Fill="#F3FFF8"/>
          </Grid>
        </Border>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="专注守卫" FontSize="24" FontWeight="Bold"/>
          <TextBlock Text="把注意力留给真正重要的事" Margin="0,4,0,0" Foreground="#68736E" FontSize="12"/>
        </StackPanel>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
        <Border x:Name="StatusBadgeContainer" Background="#E7ECE8" CornerRadius="18" Padding="14,8">
          <StackPanel Orientation="Horizontal">
            <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#89928D" Margin="0,0,8,0"/>
            <TextBlock x:Name="StatusBadge" Text="准备就绪" Foreground="#53605A" FontWeight="SemiBold" FontSize="12"/>
          </StackPanel>
        </Border>
        <Button x:Name="HideButton" Content="最小化" Style="{StaticResource SmallButton}"
                Margin="10,0,0,0" ToolTip="保留在任务栏，不退出"/>
        <Button x:Name="ExitButton" Content="退出" Style="{StaticResource SmallButton}"
                Margin="8,0,0,0" ToolTip="完全退出专注守卫"/>
      </StackPanel>
    </Grid>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="415"/>
        <ColumnDefinition Width="20"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <Border Grid.Column="0" Background="#FBFCFA" CornerRadius="16" Padding="22"
              BorderBrush="#DDE5DF" BorderThickness="1">
        <Border.Effect>
          <DropShadowEffect Color="#20382F" BlurRadius="18" ShadowDepth="3" Opacity="0.08"/>
        </Border.Effect>
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <StackPanel Margin="0,0,0,15">
            <TextBlock Text="本轮计划" FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="先设置这一轮；高级规则放在单独页面。"
                       Foreground="#75807A" FontSize="11" Margin="0,4,0,0"/>
          </StackPanel>
          <TabControl Grid.Row="1" SelectedIndex="0" Style="{StaticResource SettingsTabControl}">
            <TabItem Header="专注设置" Style="{StaticResource SettingsTabItem}">
              <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,1,4,0">
                  <TextBlock Text="本轮目标" Style="{StaticResource FieldLabel}"/>
                  <TextBlock Text="写一个明确、可以完成的结果。" Style="{StaticResource FieldHint}" Margin="0,3,0,7"/>
                  <TextBox x:Name="TaskBox" Text="完成当前最重要的任务" ToolTip="例如：完成课程报告第一稿"/>

                  <TextBlock Text="专注时长" Style="{StaticResource FieldLabel}" Margin="0,16,0,0"/>
                  <TextBlock Text="可以直接输入分钟，或使用快捷选项。" Style="{StaticResource FieldHint}" Margin="0,3,0,7"/>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="105"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="DurationBox" Text="45" ToolTip="范围：1–480 分钟"/>
                    <TextBlock Grid.Column="1" Text="分钟" Foreground="#68756E"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                  </Grid>
                  <StackPanel Orientation="Horizontal" Margin="0,9,0,0">
                    <Button x:Name="Duration25Button" Content="25 分钟" Style="{StaticResource ChipButton}"/>
                    <Button x:Name="Duration45Button" Content="45 分钟" Style="{StaticResource ChipButton}"/>
                    <Button x:Name="Duration60Button" Content="60 分钟" Style="{StaticResource ChipButton}"/>
                  </StackPanel>

                  <Border Background="#F1F5F2" BorderBrush="#E0E7E2" BorderThickness="1"
                          CornerRadius="11" Padding="14" Margin="0,17,0,0">
                    <StackPanel>
                      <TextBlock Text="什么时候提醒我？" FontSize="13" FontWeight="Bold"/>
                      <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="13"/>
                          <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                          <TextBlock Text="无操作提醒" Style="{StaticResource FieldLabel}"/>
                          <TextBlock Text="多久没碰键鼠" Style="{StaticResource FieldHint}" Margin="0,2,0,6"/>
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*"/>
                              <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="IdleBox" Text="180" ToolTip="推荐 180 秒"/>
                            <TextBlock Grid.Column="1" Text="秒" VerticalAlignment="Center"
                                       Foreground="#6F7B75" Margin="7,0,0,0"/>
                          </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                          <TextBlock Text="跑偏宽限" Style="{StaticResource FieldLabel}"/>
                          <TextBlock Text="切走后等待多久" Style="{StaticResource FieldHint}" Margin="0,2,0,6"/>
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*"/>
                              <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="GraceBox" Text="25" ToolTip="推荐 25 秒"/>
                            <TextBlock Grid.Column="1" Text="秒" VerticalAlignment="Center"
                                       Foreground="#6F7B75" Margin="7,0,0,0"/>
                          </Grid>
                        </StackPanel>
                      </Grid>
                    </StackPanel>
                  </Border>

                  <StackPanel Margin="0,16,0,0">
                    <StackPanel>
                      <TextBlock Text="提醒语气" Style="{StaticResource FieldLabel}"/>
                      <ComboBox x:Name="ToneBox" Margin="0,7,0,0" SelectedIndex="1">
                        <ComboBoxItem Content="温和"/>
                        <ComboBoxItem Content="直接"/>
                        <ComboBoxItem Content="暴躁"/>
                      </ComboBox>
                    </StackPanel>
                    <CheckBox x:Name="SoundCheck" Content="开启系统提示音（不含语音播报）"
                              IsChecked="True" FontSize="12" Margin="0,11,0,0"/>
                  </StackPanel>
                  <TextBlock Text="只轮换具体文案，始终保持你选择的语气；48 小时内不重复。"
                             Style="{StaticResource FieldHint}" Margin="0,8,0,0"/>

                  <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="推荐：45 分钟 · 180 秒无操作 · 25 秒宽限"
                               Style="{StaticResource FieldHint}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="ResetSettingsButton" Content="恢复推荐参数"
                            Style="{StaticResource SmallButton}"/>
                  </Grid>
                </StackPanel>
              </ScrollViewer>
            </TabItem>

            <TabItem Header="允许范围" Style="{StaticResource SettingsTabItem}">
              <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,1,4,0">
                  <Border Background="#EAF4EE" BorderBrush="#D7E8DD" BorderThickness="1"
                          CornerRadius="10" Padding="13">
                    <StackPanel>
                      <TextBlock Text="规则怎么生效？" FontSize="12" FontWeight="Bold" Foreground="#24533F"/>
                      <TextBlock Text="应用名或标题关键词只要命中一项，就视为专注范围内；两项都留空表示不限制应用。"
                                 Foreground="#557166" FontSize="10" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                  </Border>

                  <TextBlock Text="允许的应用" Style="{StaticResource FieldLabel}" Margin="0,17,0,0"/>
                  <TextBlock Text="适合编辑器、Office 等始终用于工作的软件。每行一个进程名。"
                             Style="{StaticResource FieldHint}" Margin="0,3,0,7"/>
                  <TextBox x:Name="AllowedAppsBox" Height="112" AcceptsReturn="True"
                           VerticalScrollBarVisibility="Auto"
                           Text="code&#x0a;winword&#x0a;excel&#x0a;powerpnt&#x0a;notepad&#x0a;obsidian"/>
                  <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="AddCurrentAppButton" Content="＋ 加入最近使用的应用"
                            Style="{StaticResource SmallButton}"/>
                    <TextBlock Grid.Column="1" Text="例如：code、winword"
                               Style="{StaticResource FieldHint}" VerticalAlignment="Center" Margin="9,0,0,0"/>
                  </Grid>

                  <TextBlock Text="允许的窗口标题关键词" Style="{StaticResource FieldLabel}" Margin="0,18,0,0"/>
                  <TextBlock Text="适合浏览器网页。每行一个项目名、课程名或文档关键词。"
                             Style="{StaticResource FieldHint}" Margin="0,3,0,7"/>
                  <TextBox x:Name="AllowedTitlesBox" Height="122" AcceptsReturn="True"
                           VerticalScrollBarVisibility="Auto"
                           Text="Codex&#x0a;Visual Studio Code&#x0a;Microsoft Word&#x0a;Excel&#x0a;PowerPoint&#x0a;Notion&#x0a;学习&#x0a;工作&#x0a;课程&#x0a;文档"/>
                  <Border Background="#FFF6E7" BorderBrush="#F0DFC0" BorderThickness="1"
                          CornerRadius="9" Padding="11,9" Margin="0,10,0,0">
                    <TextBlock Text="提示：不要直接允许 chrome 或 msedge，否则浏览器里的娱乐网页也会被放行。"
                               Foreground="#806233" FontSize="10" TextWrapping="Wrap"/>
                  </Border>
                </StackPanel>
              </ScrollViewer>
            </TabItem>
          </TabControl>
        </Grid>
      </Border>
      <Border Grid.Column="2" Background="#162C24" CornerRadius="18" Padding="30"
              BorderBrush="#24483A" BorderThickness="1">
        <Border.Effect>
          <DropShadowEffect Color="#10251E" BlurRadius="22" ShadowDepth="5" Opacity="0.16"/>
        </Border.Effect>
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock x:Name="PhaseLabel" Text="准备开始" Foreground="#8FC4AC"
                         FontWeight="SemiBold" FontSize="12"/>
              <TextBlock x:Name="CurrentTaskLabel" Text="先写下这次要完成的事"
                         Foreground="#F7FCF9" FontSize="20" FontWeight="SemiBold"
                         Margin="0,7,0,0" TextWrapping="Wrap" MaxWidth="500"/>
            </StackPanel>
            <Border Grid.Column="1" Width="38" Height="38" CornerRadius="12" Background="#25483B">
              <Grid>
                <Ellipse Width="19" Height="19" Stroke="#78D6AA" StrokeThickness="2.5"/>
                <Ellipse Width="5" Height="5" Fill="#F5FFF9"/>
              </Grid>
            </Border>
          </Grid>

          <Grid Grid.Row="1" Margin="0,18,0,20">
            <Grid.RowDefinitions>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="剩余时间" Foreground="#80988E" FontSize="11" HorizontalAlignment="Center"/>
              <TextBlock x:Name="CountdownLabel" Text="45:00" Foreground="#FFFFFF"
                         FontFamily="Consolas" FontSize="76" FontWeight="Bold"
                         HorizontalAlignment="Center" Margin="0,3,0,0"/>
              <ProgressBar x:Name="SessionProgress" Minimum="0" Maximum="100" Value="0"
                           Width="330" Margin="0,8,0,0" Style="{StaticResource SessionProgressStyle}"/>
              <TextBlock x:Name="MonitorLabel"
                         Text="开始后将检查当前应用、窗口标题和空闲时长"
                         Foreground="#A5B8AF" FontSize="11" HorizontalAlignment="Center"
                         Margin="0,13,0,0" TextTrimming="CharacterEllipsis" MaxWidth="520"/>
            </StackPanel>
            <Border Grid.Row="1" Background="#203B31" CornerRadius="11" Padding="15,12"
                    Margin="0,18,0,0" BorderBrush="#2B5041" BorderThickness="1">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Width="30" Height="30" CornerRadius="9" Background="#2C5142" Margin="0,0,11,0">
                  <TextBlock Text="●" Foreground="#74D3A6" FontSize="11"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="最近活动窗口" Foreground="#789287" FontSize="10"/>
                  <TextBlock x:Name="WindowLabel" Text="等待检测" Foreground="#ECF4F0"
                             FontSize="12" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
              </Grid>
            </Border>
          </Grid>

          <StackPanel Grid.Row="2">
            <Grid Margin="0,0,0,17">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="9"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="9"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Border Grid.Column="0" Background="#203B31" CornerRadius="10" Padding="13,10">
                <StackPanel>
                  <TextBlock Text="提醒次数" Foreground="#80988E" FontSize="10"/>
                  <TextBlock x:Name="ReminderCountLabel" Text="0" Foreground="White"
                             FontSize="21" FontWeight="SemiBold"/>
                </StackPanel>
              </Border>
              <Border Grid.Column="2" Background="#203B31" CornerRadius="10" Padding="13,10">
                <StackPanel>
                  <TextBlock Text="主动返回" Foreground="#80988E" FontSize="10"/>
                  <TextBlock x:Name="ReturnCountLabel" Text="0" Foreground="White"
                             FontSize="21" FontWeight="SemiBold"/>
                </StackPanel>
              </Border>
              <Border Grid.Column="4" Background="#203B31" CornerRadius="10" Padding="13,10">
                <StackPanel>
                  <TextBlock Text="已进行" Foreground="#80988E" FontSize="10"/>
                  <TextBlock x:Name="FocusedTimeLabel" Text="0 分钟" Foreground="White"
                             FontSize="21" FontWeight="SemiBold"/>
                </StackPanel>
              </Border>
            </Grid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
              <Button x:Name="StartButton" Content="开始专注"
                      Style="{StaticResource PrimaryButton}" Width="145"/>
              <Button x:Name="PauseButton" Content="暂停"
                      Style="{StaticResource SecondaryButton}" Width="106"
                      Margin="10,0,0,0" IsEnabled="False"/>
              <Button x:Name="EndBreakButton" Content="结束休息"
                      Style="{StaticResource SecondaryButton}" Width="106"
                      Margin="10,0,0,0" Visibility="Collapsed"/>
              <Button x:Name="StopButton" Content="结束专注"
                      Style="{StaticResource DangerButton}" Width="104"
                      Margin="10,0,0,0" IsEnabled="False"/>
            </StackPanel>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>

    <Grid Grid.Row="2" Margin="2,15,2,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Text="仅在本机检查空闲时长、应用名和窗口标题；不截屏、不读取按键内容、不上传数据。"
                 Foreground="#75807A" FontSize="10" VerticalAlignment="Center"/>
      <TextBlock Grid.Column="1" Text="关闭会收起窗口并继续运行 · 退出按钮才会完全关闭"
                 Foreground="#89938E" FontSize="10" VerticalAlignment="Center"/>
    </Grid>
  </Grid>
</Window>
