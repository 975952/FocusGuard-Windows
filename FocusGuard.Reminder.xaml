<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="专注守卫提醒" Width="630" Height="360"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        ResizeMode="NoResize" Topmost="True" ShowInTaskbar="False"
        AllowsTransparency="True" Background="Transparent"
        FontFamily="Microsoft YaHei UI" UseLayoutRounding="True">
  <Window.Resources>
    <Style x:Key="AlertButton" TargetType="Button">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="9" Padding="{TemplateBinding Padding}" RenderTransformOrigin="0.5,0.5">
              <Border.RenderTransform>
                <ScaleTransform x:Name="ButtonScale" ScaleX="1" ScaleY="1"/>
              </Border.RenderTransform>
              <Grid>
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Border x:Name="ShadeLayer" Background="#0B1F17" Opacity="0"
                        CornerRadius="8" IsHitTestVisible="False"/>
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ShadeLayer" Property="Opacity" Value="0.08"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="ShadeLayer" Property="Opacity" Value="0.22"/>
                <Setter TargetName="ButtonBorder" Property="RenderTransform">
                  <Setter.Value>
                    <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                  </Setter.Value>
                </Setter>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.38"/>
                <Setter Property="Cursor" Value="Arrow"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>
  <Border Background="#FBFCF9" BorderBrush="#183A2D" BorderThickness="2"
          CornerRadius="20" Padding="32">
    <Border.Effect>
      <DropShadowEffect Color="#10251E" BlurRadius="28" ShadowDepth="8" Opacity="0.28"/>
    </Border.Effect>
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Width="44" Height="44" CornerRadius="14" Background="#F7E5DF" Margin="0,0,14,0">
          <TextBlock Text="!" Foreground="#B44F3F" FontSize="22" FontWeight="Bold"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <StackPanel Grid.Column="1" VerticalAlignment="Center">
          <TextBlock x:Name="AlertKicker" Text="注意力提醒" Foreground="#A44A3C"
                     FontSize="11" FontWeight="Bold"/>
          <TextBlock x:Name="AlertTitle" Text="该回来了。" Foreground="#17211D"
                     FontSize="27" FontWeight="Bold" Margin="0,3,0,0"/>
        </StackPanel>
      </Grid>
      <StackPanel Grid.Row="1" VerticalAlignment="Center">
        <TextBlock x:Name="AlertMessage" Text="" Foreground="#2A352F"
                   FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"/>
        <Border Background="#EEF2EE" BorderBrush="#DDE5DF" BorderThickness="1"
                CornerRadius="9" Padding="13,10" Margin="0,17,0,0">
          <TextBlock x:Name="AlertContext" Text="" Foreground="#6F7B75"
                     FontSize="11" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                     MaxHeight="44"/>
        </Border>
      </StackPanel>
      <Grid Grid.Row="2">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="Enter 返回 · Esc 休息" Foreground="#919B96"
                   FontSize="10" VerticalAlignment="Center"/>
        <StackPanel Grid.Column="1" Orientation="Horizontal">
          <Button x:Name="BreakButton" Content="休息 5 分钟" Style="{StaticResource AlertButton}"
                  Background="#E8EFEA" Foreground="#2A473B"
                  BorderBrush="#D4DED7" BorderThickness="1"
                  Padding="17,10" FontWeight="SemiBold" Cursor="Hand" IsCancel="True"/>
          <Button x:Name="ReturnButton" Content="现在就回来" Style="{StaticResource AlertButton}"
                  Background="#167A57" Foreground="White" BorderThickness="0"
                  Padding="21,11" FontWeight="SemiBold" Margin="10,0,0,0"
                  Cursor="Hand" IsDefault="True"/>
        </StackPanel>
      </Grid>
    </Grid>
  </Border>
</Window>
