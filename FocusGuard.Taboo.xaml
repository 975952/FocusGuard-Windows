<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="专注守卫 · 绝对禁止"
        WindowStyle="None" ResizeMode="NoResize" Topmost="True"
        ShowInTaskbar="False" WindowState="Maximized"
        Background="#180B09" FontFamily="Microsoft YaHei UI"
        UseLayoutRounding="True" SnapsToDevicePixels="True">
  <Grid>
    <Border VerticalAlignment="Center" HorizontalAlignment="Center"
            Background="#24110E" BorderBrush="#6E2A22" BorderThickness="1"
            CornerRadius="22" Padding="64,52" MaxWidth="860">
      <StackPanel HorizontalAlignment="Center">
        <TextBlock x:Name="TabooKickerLabel" Text="绝对禁止内容" Foreground="#E8826F"
                   FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
        <TextBlock Text="立刻离开这个页面。" Foreground="#FBF3F0" FontSize="40"
                   FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
        <Border Background="#3A1712" BorderBrush="#8A352A" BorderThickness="1"
                CornerRadius="10" Padding="22,9" Margin="0,26,0,0"
                HorizontalAlignment="Center">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="命中词汇：" Foreground="#C9917F" FontSize="14"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="TabooWordLabel" Text="" Foreground="#FFD9CF"
                       FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
          </StackPanel>
        </Border>
        <TextBlock x:Name="TabooContextLabel" Text="" Foreground="#A97E72"
                   FontSize="12" HorizontalAlignment="Center" Margin="0,12,0,0"
                   TextTrimming="CharacterEllipsis" MaxWidth="720"/>
        <TextBlock x:Name="TabooCountdownLabel" Text="15" Foreground="#FFFFFF"
                   FontFamily="Consolas" FontSize="96" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,26,0,0"/>
        <TextBlock Text="秒后解除锁定" Foreground="#C9917F" FontSize="13"
                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
        <TextBlock x:Name="TabooStrikeLabel" Text="" Foreground="#E8A08D"
                   FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"
                   Margin="0,22,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
        <Separator Margin="0,24,0,16" Background="#4A201A"/>
        <TextBlock Text="此窗口无法关闭，请等待倒计时结束。倒计时结束后立即回到没有禁忌内容的界面，否则会再次锁定且时间更长。"
                   Foreground="#8F6A60" FontSize="11" TextWrapping="Wrap"
                   TextAlignment="Center" HorizontalAlignment="Center" MaxWidth="620"/>
      </StackPanel>
    </Border>
  </Grid>
</Window>
