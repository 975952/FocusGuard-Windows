<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="专注成绩档案" Width="1280" Height="960" MinWidth="1040" MinHeight="800"
        WindowStartupLocation="CenterOwner" Background="#F3F6F2"
        FontFamily="Microsoft YaHei UI" ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip" UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Ideal">
  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="#17211D"/>
      <Setter Property="Padding" Value="0,0,4,0"/>
      <Setter Property="ClipToBounds" Value="False"/>
    </Style>
    <Style x:Key="MetricCard" TargetType="Border">
      <Setter Property="Background" Value="#FFFFFF"/><Setter Property="BorderBrush" Value="#DCE5DF"/>
      <Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="16,11"/>
    </Style>
    <Style x:Key="PrimaryButton" TargetType="Button">
      <Setter Property="Background" Value="#167A57"/><Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderThickness" Value="0"/><Setter Property="Padding" Value="20,10"/>
      <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
        <Border Background="{TemplateBinding Background}" CornerRadius="9" Padding="{TemplateBinding Padding}">
          <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
      </ControlTemplate></Setter.Value></Setter>
      <Style.Triggers><Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#CBD5CF"/><Setter Property="Foreground" Value="#7A8880"/></Trigger></Style.Triggers>
    </Style>
    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
      <Setter Property="Background" Value="#E5ECE7"/><Setter Property="Foreground" Value="#31483E"/>
    </Style>
    <Style x:Key="PanelSplitter" TargetType="GridSplitter">
      <Setter Property="Background" Value="Transparent"/><Setter Property="Cursor" Value="SizeWE"/><Setter Property="Focusable" Value="False"/>
      <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="GridSplitter">
        <Grid Background="Transparent"><Border x:Name="Grip" Width="3" Height="44" CornerRadius="2" Background="#D5DFD9" HorizontalAlignment="Center" VerticalAlignment="Center"/></Grid>
        <ControlTemplate.Triggers>
          <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Grip" Property="Width" Value="4"/><Setter TargetName="Grip" Property="Height" Value="72"/><Setter TargetName="Grip" Property="Background" Value="#16825C"/></Trigger>
          <Trigger Property="IsDragging" Value="True"><Setter TargetName="Grip" Property="Width" Value="4"/><Setter TargetName="Grip" Property="Height" Value="96"/><Setter TargetName="Grip" Property="Background" Value="#167A57"/></Trigger>
        </ControlTemplate.Triggers>
      </ControlTemplate></Setter.Value></Setter>
    </Style>
    <Style TargetType="ListViewItem">
      <Setter Property="Padding" Value="4,8,10,8"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="BorderBrush" Value="#E7ECE8"/><Setter Property="BorderThickness" Value="0,0,0,1"/>
      <Style.Triggers><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#DFF1E8"/><Setter Property="Foreground" Value="#173F30"/></Trigger></Style.Triggers>
    </Style>
  </Window.Resources>

  <Grid Margin="22">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
      <RowDefinition Height="214"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="2,0,2,14">
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <StackPanel>
        <TextBlock Text="专注成绩档案" FontSize="25" FontWeight="Bold"/>
        <TextBlock Text="先看最近发生了什么，再看它是否正在变成一种模式。" Foreground="#65736C" FontSize="12" Margin="0,5,0,0"/>
      </StackPanel>
      <Border Grid.Column="1" Background="#E5EEE8" CornerRadius="16" Padding="13,7" VerticalAlignment="Center">
        <TextBlock Text="仅存本机 · 最近 100 轮" Foreground="#486357" FontSize="11" FontWeight="SemiBold"/>
      </Border>
    </Grid>

    <Border Grid.Row="1" Background="#162C24" BorderBrush="#24483A" BorderThickness="1" CornerRadius="15" Padding="20,15,22,15" Margin="0,0,0,12">
      <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="260"/></Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock x:Name="AccountabilityHeadline" Text="先积累第一轮真实成绩" Foreground="#F4FBF7" FontSize="17" FontWeight="Bold"/>
          <TextBlock x:Name="AccountabilityText" Text="历史会指出重复出现的问题，但不会用少量样本给你贴标签。"
                     Foreground="#A7BDB3" FontSize="11" TextWrapping="Wrap" LineHeight="19" Margin="0,6,22,0"/>
        </StackPanel>
        <Border Grid.Column="1" Background="#203B31" CornerRadius="10" Padding="14,10" VerticalAlignment="Center">
          <StackPanel>
            <TextBlock Text="当前最常见的丢分信号" Foreground="#7F9B8F" FontSize="10"/>
            <TextBlock x:Name="WeakestDimensionLabel" Text="等待更多数据" Foreground="#FFFFFF" FontSize="15" FontWeight="Bold" Margin="0,4,0,0" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Row="2" Margin="0,0,0,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/>
        <ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <Border Grid.Column="0" Style="{StaticResource MetricCard}"><StackPanel><TextBlock Text="记录轮次" Foreground="#718078" FontSize="10"/><TextBlock x:Name="TotalSessionsValue" Text="0" FontSize="22" FontWeight="Bold" Margin="0,2,0,0"/></StackPanel></Border>
      <Border Grid.Column="2" Style="{StaticResource MetricCard}"><StackPanel><TextBlock Text="平均得分" Foreground="#718078" FontSize="10"/><TextBlock x:Name="AverageScoreValue" Text="--" FontSize="22" FontWeight="Bold" Margin="0,2,0,0"/></StackPanel></Border>
      <Border Grid.Column="4" Style="{StaticResource MetricCard}"><StackPanel><TextBlock Text="按时完成率" Foreground="#718078" FontSize="10"/><TextBlock x:Name="CompletionRateValue" Text="--" FontSize="22" FontWeight="Bold" Margin="0,2,0,0"/></StackPanel></Border>
      <Border Grid.Column="6" Style="{StaticResource MetricCard}"><StackPanel><TextBlock Text="累计有效进行" Foreground="#718078" FontSize="10"/><TextBlock x:Name="TotalMinutesValue" Text="0 分钟" FontSize="22" FontWeight="Bold" Margin="0,2,0,0"/></StackPanel></Border>
    </Grid>

    <Border Grid.Row="3" Background="#FFFFFF" BorderBrush="#DCE5DF" BorderThickness="1" CornerRadius="13" Padding="17,13,21,13" Margin="0,0,0,12">
      <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="18"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Grid>
          <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="质量投入轨迹" FontSize="15" FontWeight="Bold"/>
            <TextBlock Text="  ·  最近 18 周" Foreground="#78847E" FontSize="11" VerticalAlignment="Bottom" Margin="4,0,0,1"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="少" Foreground="#78847E" FontSize="10" Margin="0,0,6,0"/>
            <Border Width="12" Height="12" CornerRadius="3" Background="#E7ECE9" Margin="2,0"/><Border Width="12" Height="12" CornerRadius="3" Background="#D2E7E8" Margin="2,0"/>
            <Border Width="12" Height="12" CornerRadius="3" Background="#8CC6CB" Margin="2,0"/><Border Width="12" Height="12" CornerRadius="3" Background="#4497A0" Margin="2,0"/>
            <Border Width="12" Height="12" CornerRadius="3" Background="#17616C" Margin="2,0"/><TextBlock Text="多" Foreground="#78847E" FontSize="10" Margin="6,0,0,0"/>
          </StackPanel>
        </Grid>
        <Grid x:Name="HeatmapMonthLabels" Grid.Row="1" Margin="28,1,0,0"/>
        <Grid Grid.Row="2">
          <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
          <Grid>
            <TextBlock Text="一" Foreground="#839088" FontSize="9" VerticalAlignment="Top" Margin="3,5,0,0"/>
            <TextBlock Text="三" Foreground="#839088" FontSize="9" VerticalAlignment="Center" Margin="3,0,0,0"/>
            <TextBlock Text="五" Foreground="#839088" FontSize="9" VerticalAlignment="Bottom" Margin="3,0,0,5"/>
          </Grid>
          <Grid x:Name="HeatmapGrid" Grid.Column="1"/>
        </Grid>
        <TextBlock x:Name="HeatmapSummaryLabel" Grid.Row="3" Text="深色代表更高的质量投入，不只是坐得更久。"
                   Foreground="#5D6E65" FontSize="10" TextWrapping="Wrap" Margin="28,7,0,0"/>
      </Grid>
    </Border>

    <Grid Grid.Row="4">
      <Grid.ColumnDefinitions>
        <ColumnDefinition x:Name="HistoryInsightColumn" Width="380" MinWidth="320" MaxWidth="520"/>
        <ColumnDefinition Width="12"/><ColumnDefinition Width="*" MinWidth="560"/>
      </Grid.ColumnDefinitions>
      <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <Border Background="#FFFFFF" BorderBrush="#DCE5DF" BorderThickness="1" CornerRadius="13" Padding="16,16,22,16" Margin="0,0,8,0">
        <Grid>
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="112"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
          <StackPanel><TextBlock Text="最近的变化" FontSize="15" FontWeight="Bold"/><TextBlock Text="柱子只负责显示波动，文字负责解释。" Foreground="#78847E" FontSize="10" Margin="0,3,0,0"/></StackPanel>
          <UniformGrid x:Name="TrendBarsPanel" Grid.Row="1" Rows="1" Margin="0,9,0,4"/>
          <TextBlock x:Name="TrendSummaryLabel" Grid.Row="2" Text="暂无趋势" Foreground="#52645A" FontSize="11" TextWrapping="Wrap" LineHeight="18"/>
          <Border Grid.Row="3" Background="#EEF5F2" BorderBrush="#D8E7E0" BorderThickness="1" CornerRadius="9" Padding="11,9" Margin="0,10,0,0">
            <StackPanel>
              <TextBlock Text="放到更长时间里看" Foreground="#2D5B49" FontSize="10" FontWeight="Bold"/>
              <TextBlock x:Name="LongTermInsightLabel" Text="样本不足时不会硬套结论。" Foreground="#486357" FontSize="10" TextWrapping="Wrap" LineHeight="17" Margin="0,4,0,0"/>
            </StackPanel>
          </Border>
          <Border Grid.Row="4" Background="#FFF7E8" BorderBrush="#EDDFC0" BorderThickness="1" CornerRadius="9" Padding="11,9" Margin="0,9,0,0">
            <StackPanel><TextBlock Text="复盘纪律" Foreground="#785B1C" FontSize="10" FontWeight="Bold"/><TextBlock x:Name="ReviewStatusLabel" Text="暂无待复盘记录" Foreground="#705D35" FontSize="10" TextWrapping="Wrap" Margin="0,4,0,0"/></StackPanel>
          </Border>
        </Grid>
      </Border>
      </ScrollViewer>

      <GridSplitter x:Name="HistoryPaneSplitter" Grid.Column="1" Width="12" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Style="{StaticResource PanelSplitter}" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" ShowsPreview="False"
                    ToolTip="拖动调整分析区与明细区；双击恢复推荐宽度"/>

      <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#DCE5DF" BorderThickness="1" CornerRadius="13" Padding="16,16,22,16">
        <Grid>
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
          <StackPanel Margin="0,0,0,9">
            <TextBlock Text="历史明细" FontSize="15" FontWeight="Bold"/>
            <TextBlock Text="选择或双击任意一轮，查看完整分析。" Foreground="#7B8780" FontSize="10" Margin="0,3,0,0"/>
          </StackPanel>
          <Grid Grid.Row="1">
            <ListView x:Name="HistoryList" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
              <ListView.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,0,12,0">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="48"/><ColumnDefinition Width="58"/></Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Date}" Foreground="#66756D" FontSize="10" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="1" Text="{Binding Task}" FontSize="12" FontWeight="SemiBold" Margin="6,0,6,0" TextTrimming="CharacterEllipsis"/>
                    <Border Grid.Column="2" Background="#EDF4EF" CornerRadius="6" Padding="5,2" Margin="0,0,5,0"><TextBlock Text="{Binding Score}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/></Border>
                    <TextBlock Grid.Column="3" Text="{Binding Review}" FontSize="10" Foreground="#52645A" VerticalAlignment="Center" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="6,5,0,0">
                      <TextBlock Foreground="#78847E" FontSize="10"><Run Text="专注 "/><Run Text="{Binding Focus}"/></TextBlock>
                      <TextBlock Foreground="#78847E" FontSize="10" Margin="12,0,0,0"><Run Text="进度 "/><Run Text="{Binding Progress}"/></TextBlock>
                      <TextBlock Foreground="#78847E" FontSize="10" Margin="12,0,0,0"><Run Text="提醒 "/><Run Text="{Binding Reminders}"/><Run Text=" 次"/></TextBlock>
                    </StackPanel>
                  </Grid>
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
            <TextBlock x:Name="EmptyHistoryLabel" Text="还没有历史记录。先完成一轮，再来面对真实数据。" Foreground="#7A8780" FontSize="12" TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <Grid Grid.Row="5" Margin="2,13,2,0">
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <Button Grid.Column="1" x:Name="ViewSelectedButton" Content="查看选中分析" Style="{StaticResource PrimaryButton}" IsEnabled="False"/>
      <Button Grid.Column="2" x:Name="CloseHistoryButton" Content="关闭" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0"/>
    </Grid>
  </Grid>
</Window>
